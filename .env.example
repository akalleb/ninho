# Configurações do Supabase (Obrigatório)
# Obtenha estas chaves no Dashboard do Supabase: Project Settings -> API
SUPABASE_URL=https://jpmmnhecpowxigwqgphk.supabase.co
# IMPORTANTE: Use a chave 'anon' (pública) aqui. NÃO use a 'service_role' key!
SUPABASE_ANON_KEY=sua_chave_anon_publica_aqui
# A chave service_role é usada apenas pelo backend para tarefas administrativas
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_secreta_aqui

# Configurações do Banco de Dados (Obrigatório)
# Connection String do Supabase (Transaction Pooler na porta 6543 ou Session na 5432)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.jpmmnhecpowxigwqgphk.supabase.co:5432/postgres

# Segurança (Gere uma chave aleatória forte, ex: openssl rand -base64 32)
ENCRYPTION_KEY=sua_chave_de_criptografia_aqui

# Configurações de Armazenamento (Buckets do Supabase e R2)
FAMILY_DOCS_BUCKET=families-docs
CHILD_DOCS_BUCKET=child-docs

# Cloudflare R2 (Se estiver usando)
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY_ID=seu_access_key_id
R2_SECRET_ACCESS_KEY=seu_secret_access_key
R2_BUCKET_NAME=ninho-docs
NEXT_PUBLIC_R2_PUBLIC_URL=https://seu-r2-url.com
